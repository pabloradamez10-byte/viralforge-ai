// ViralForge AI — Database Schema
// PostgreSQL + Prisma
// Convenções: UUIDs, timestamps UTC, enums explícitos.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Enums ───────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum UserPlan {
  FREE
  PRO
  AGENCY
  ENTERPRISE
}

enum SourceType {
  GOOGLE_TRENDS
  YOUTUBE
  REDDIT
  TIKTOK
  GOOGLE_NEWS
  RSS
  HACKERNEWS
}

enum InsightKind {
  GROWTH
  DECLINE
  OPPORTUNITY
  SATURATION
  EMERGING
  ALERT
  STRATEGY
}

enum PlanStatus {
  DRAFT
  GENERATED
  ARCHIVED
}

// ─────────────────────────── User ───────────────────────────

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  passwordHash  String   @map("password_hash")
  name          String
  avatarUrl     String?  @map("avatar_url")
  role          UserRole @default(USER)
  plan          UserPlan @default(FREE)
  emailVerified Boolean  @default(false) @map("email_verified")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  projects      Project[]
  searches      TrendSearch[]
  insights      Insight[]
  contentPlans  ContentPlan[]
  apiKeys       UserApiKey[]
  auditLogs     AuditLog[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  userAgent String?   @map("user_agent")
  ip        String?
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─────────────────────────── Project ───────────────────────────

model Project {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  description String?
  niche       String?
  settings    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  searches     TrendSearch[]
  contentPlans ContentPlan[]
  insights     Insight[]

  @@index([userId])
  @@map("projects")
}

// ─────────────────────────── Sources & Categories ───────────────────────────

model Source {
  id        String     @id @default(uuid()) @db.Uuid
  slug      String     @unique
  name      String
  type      SourceType
  baseUrl   String?    @map("base_url")
  active    Boolean    @default(true)
  config    Json       @default("{}")
  createdAt DateTime   @default(now()) @map("created_at")

  records   TrendRecord[]
  apiKeys   UserApiKey[]

  @@map("sources")
}

model Category {
  id       String     @id @default(uuid()) @db.Uuid
  slug     String     @unique
  name     String
  parentId String?    @map("parent_id") @db.Uuid
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  records  TrendRecord[]

  @@map("categories")
}

// ─────────────────────────── Trends ───────────────────────────

model TrendSearch {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  projectId String?  @map("project_id") @db.Uuid
  query     String
  region    String   @default("global")
  language  String   @default("en")
  filters   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  records       TrendRecord[]
  metrics       TrendMetric[]
  insights      Insight[]
  contentPlans  ContentPlan[]

  @@index([userId, createdAt])
  @@index([query])
  @@map("trend_searches")
}

model TrendRecord {
  id           String   @id @default(uuid()) @db.Uuid
  searchId     String   @map("search_id") @db.Uuid
  sourceId     String   @map("source_id") @db.Uuid
  categoryId   String?  @map("category_id") @db.Uuid
  externalId   String?  @map("external_id")
  title        String
  url          String?
  payload      Json     @default("{}")
  collectedAt  DateTime @default(now()) @map("collected_at")
  publishedAt  DateTime? @map("published_at")

  search   TrendSearch   @relation(fields: [searchId], references: [id], onDelete: Cascade)
  source   Source        @relation(fields: [sourceId], references: [id])
  category Category?     @relation(fields: [categoryId], references: [id])
  metrics  TrendMetric[]

  @@index([sourceId, collectedAt(sort: Desc)])
  @@index([searchId])
  @@index([title])
  @@map("trend_records")
}

model TrendMetric {
  id                String   @id @default(uuid()) @db.Uuid
  recordId          String   @map("record_id") @db.Uuid
  searchId          String   @map("search_id") @db.Uuid
  volume            Int      @default(0)
  growthPct         Int      @default(0) @map("growth_pct")
  declinePct        Int      @default(0) @map("decline_pct")
  competitionScore  Float    @default(0) @map("competition_score")
  opportunityScore  Float    @default(0) @map("opportunity_score")
  seasonalityScore  Float    @default(0) @map("seasonality_score")
  lifetimeDays      Int      @default(0) @map("lifetime_days")
  popularity        Int      @default(0)
  timeSeries        Json     @default("[]") @map("time_series")
  snapshotDate      DateTime @default(now()) @map("snapshot_date") @db.Date

  record TrendRecord  @relation(fields: [recordId], references: [id], onDelete: Cascade)
  search TrendSearch  @relation(fields: [searchId], references: [id], onDelete: Cascade)

  @@unique([recordId, snapshotDate])
  @@index([snapshotDate, recordId])
  @@index([opportunityScore(sort: Desc)])
  @@map("trend_metrics")
}

// ─────────────────────────── Insights & Strategy ───────────────────────────

model Insight {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  projectId   String?     @map("project_id") @db.Uuid
  searchId    String?     @map("search_id") @db.Uuid
  kind        InsightKind
  title       String
  body        String
  explanation String
  evidence    Json        @default("[]")
  confidence  Float       @default(0)
  createdAt   DateTime    @default(now()) @map("created_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  search  TrendSearch? @relation(fields: [searchId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@map("insights")
}

// ─────────────────────────── Content Plans ───────────────────────────

model ContentPlan {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  projectId String?    @map("project_id") @db.Uuid
  searchId  String?    @map("search_id") @db.Uuid
  title     String
  status    PlanStatus @default(GENERATED)
  createdAt DateTime   @default(now()) @map("created_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  search  TrendSearch? @relation(fields: [searchId], references: [id], onDelete: SetNull)
  ideas   ContentIdea[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("content_plans")
}

model ContentIdea {
  id             String  @id @default(uuid()) @db.Uuid
  planId         String  @map("plan_id") @db.Uuid
  position       Int
  title          String
  hook           String
  description    String
  cta            String
  hashtags       String
  keywords       String
  videoStructure Json    @default("{}") @map("video_structure")

  plan ContentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, position])
  @@map("content_ideas")
}

// ─────────────────────────── API Keys ───────────────────────────

model UserApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  sourceId   String    @map("source_id") @db.Uuid
  label      String
  encryptedKey String  @map("encrypted_key")
  meta       Json      @default("{}")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceId, label])
  @@map("user_api_keys")
}

// ─────────────────────────── Audit ───────────────────────────

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  resource  String
  metadata  Json     @default("{}")
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([action])
  @@map("audit_logs")
}
