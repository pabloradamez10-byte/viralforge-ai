# ── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_NAME="ViralForge AI"
APP_URL=http://localhost:5173
API_URL=http://localhost:4000
LOG_LEVEL=info

# ── Security ─────────────────────────────────────────
JWT_SECRET=replace-with-32-byte-random-secret
JWT_REFRESH_SECRET=replace-with-another-32-byte-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
ENCRYPTION_KEY=replace-with-32-byte-base64-key
BCRYPT_COST=12

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://viralforge:viralforge@localhost:5432/viralforge?schema=public

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI Provider ──────────────────────────────────────
# Escolha um: openai | anthropic | ollama
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── External APIs ────────────────────────────────────
YOUTUBE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ViralForgeAI/1.0
SERPAPI_KEY=

# ── Rate Limit ───────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ── CORS ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
